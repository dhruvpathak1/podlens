# Copy to `.env` in this folder and fill in values. `.env` is gitignored.
# API server loads this via python-dotenv (see server/main.py).

# --- Unsplash (stock images on entity source cards) ---
# https://unsplash.com/developers — create an app to get keys.
#
# "Access Key" in the dashboard → required. Sent as: Authorization: Client-ID <key>
UNSPLASH_ACCESS_KEY=
#
# "Secret key" — used for OAuth (user login flow), not for the photo search we call.
# Optional here; safe to leave blank unless you add OAuth later.
UNSPLASH_SECRET_KEY=

# --- Claude (classic CoNLL-style NER: PERSON, ORG→COMPANY, LOC→PLACE, MISC) ---
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# (alias: claude-haiku-4-5 — see https://docs.anthropic.com/en/docs/about-claude/models )
# When the key is set and ENTITY_BACKEND is unset, the server defaults to Claude.

# --- Whisper (optional overrides) ---
# WHISPER_MODEL=base
# WHISPER_DOWNLOAD_ROOT=
# TORCH_HOME=

# --- Storage paths (defaults under server/) ---
# TRANSCRIPTS_DIR=
# ENTITY_JSON_DIR=

# --- Entity pipeline ---
# ENTITY_BACKEND=spacy
# (omit or use claude; with ANTHROPIC_API_KEY set, omitting ENTITY_BACKEND selects Claude)
# SPACY_MODEL=en_core_web_sm
# CLAUDE_ENTITY_BATCH=12
#
# Better tagging (pick one or combine):
# 1) Stronger Whisper → WHISPER_MODEL=small (or medium) — cleaner text = better NER.
# 2) Stronger spaCy → pip install en_core_web_md or en_core_web_lg then SPACY_MODEL=en_core_web_md
#    (sm is fast but misses/confuses entities vs md/lg).
# 3) Claude → ENTITY_BACKEND=claude + ANTHROPIC_API_KEY — best for messy podcast speech (costs API $).
# 4) Frontend forces Claude if server allows: VITE_ENTITY_BACKEND=claude

# --- HTTP identity for Wikimedia / Nominatim (use a real contact URL if public) ---
# NOMINATIM_USER_AGENT=MyPodcastApp/1.0 (you@example.com)
# --- Vite (frontend). Only vars prefixed VITE_ are exposed in the browser. ---
# Full API base when not using the dev proxy, e.g. http://127.0.0.1:8000/api/transcribe
# VITE_TRANSCRIBE_URL=
#
# GitHub Pages (static site) cannot host this API; deploy FastAPI elsewhere and set the same URL in
# GitHub Actions secret VITE_TRANSCRIBE_URL when building. Allow the Pages origin on the server, e.g.:
# CORS_EXTRA_ORIGINS=https://your-github-username.github.io
# Force entity extractor from the UI: spacy | claude
# VITE_ENTITY_BACKEND=
